generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Attendance {
  id            Int      @id @default(autoincrement())
  name          String
  workDate      DateTime
  clockIn       String
  clockOut      String
  breakMinutes  Int
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkEntry {
  id           Int      @id @default(autoincrement())
  userId       Int
  workDate     DateTime
  rowIndex     Int
  orderCode    String   @db.VarChar(9)
  isTravel     Boolean  @default(false)
  process      String   @db.VarChar(2)
  detail       String   @db.VarChar(2)
  orderName    String
  startTime    String   @db.VarChar(5)
  endTime      String   @db.VarChar(5)
  workContent  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workDate])
}

model DailyAttendanceCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  workDate  DateTime
  code      String   @db.VarChar(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workDate])
  @@index([userId, workDate])
}

model UserSetting {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  opNo          String   @db.VarChar(3)
  name          String
  workStartTime String   @default("09:00") @db.VarChar(5)
  workEndTime   String   @default("18:00") @db.VarChar(5)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id           Int      @id @default(autoincrement())
  loginId      String   @unique @db.VarChar(50)
  passwordHash String
  name         String
  opNo         String   @db.VarChar(20)
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workEntries  WorkEntry[]
  dayCodes     DailyAttendanceCode[]
  setting      UserSetting?
  orderPresets OrderPreset[]

  @@index([loginId])
}

model OrderPreset {
  id           Int      @id @default(autoincrement())
  userId       Int
  displayOrder Int
  orderNo      String   @db.VarChar(9)
  orderName    String
  time1Start   String   @db.VarChar(5)
  time1End     String   @db.VarChar(5)
  time2Start   String   @db.VarChar(5)
  time2End     String   @db.VarChar(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}
