generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Attendance {
  id            Int      @id @default(autoincrement())
  name          String
  workDate      DateTime
  clockIn       String
  clockOut      String
  breakMinutes  Int
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkEntry {
  id           Int      @id @default(autoincrement())
  workDate     DateTime
  rowIndex     Int
  orderCode    String   @db.VarChar(9)
  isTravel     Boolean  @default(false)
  process      String   @db.VarChar(2)
  detail       String   @db.VarChar(2)
  orderName    String
  startTime    String   @db.VarChar(5)
  endTime      String   @db.VarChar(5)
  workContent  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workDate])
}

model DailyAttendanceCode {
  id        Int      @id @default(autoincrement())
  workDate  DateTime @unique
  code      String   @db.VarChar(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workDate])
}

model UserSetting {
  id            Int      @id @default(1)
  opNo          String   @db.VarChar(3)
  name          String
  workStartTime String   @default("09:00") @db.VarChar(5)
  workEndTime   String   @default("18:00") @db.VarChar(5)
  updatedAt     DateTime @updatedAt
}

model OrderPreset {
  id           Int      @id @default(autoincrement())
  displayOrder Int
  orderNo      String   @db.VarChar(9)
  orderName    String
  time1Start   String   @db.VarChar(5)
  time1End     String   @db.VarChar(5)
  time2Start   String   @db.VarChar(5)
  time2End     String   @db.VarChar(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
}
